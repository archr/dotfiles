#!/bin/bash
# Display Claude Code instance states for tmux status bar

STATE_DIR="/tmp/claude-state"
CURRENT_WIN="$1"  # Current window index passed from tmux
output=""

# Colors
yellow="#[fg=#ffb86c]"
grey="#[fg=#6272a4]"
reset="#[fg=#f8f8f2]"

# Get all tmux panes with Claude running
# pane_current_command shows version number (e.g., "2.1.19") for Claude
while IFS='|' read -r tty win_idx win_name cmd; do
    # Check if this pane is running Claude (version pattern or "claude")
    if [[ "$cmd" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || [[ "$cmd" == "claude" ]]; then
        # Extract tty name (remove /dev/ prefix)
        tty_name="${tty#/dev/}"
        state_file="$STATE_DIR/$tty_name"

        if [[ -f "$state_file" ]]; then
            state=$(cat "$state_file" 2>/dev/null)
        else
            state="WORKING"
        fi

        # Yellow only for current window, grey for others
        if [[ "$win_idx" == "$CURRENT_WIN" ]]; then
            num_color="$yellow"
        else
            num_color="$grey"
        fi

        # Format with emojis
        case "$state" in
            APPROVAL)
                indicator="${num_color}${win_idx}${reset}:🔔"
                ;;
            DONE)
                indicator="${num_color}${win_idx}${reset}:✅"
                ;;
            *)
                indicator="${num_color}${win_idx}${reset}:🔄"
                ;;
        esac

        output="$output $indicator"
    fi
done < <(tmux list-panes -s -F "#{pane_tty}|#{window_index}|#{window_name}|#{pane_current_command}" 2>/dev/null)

# Output trimmed result
echo "${output# }"
