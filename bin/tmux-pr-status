#!/bin/bash
# tmux-pr-status - Show GitHub PR status for current branch
# Usage: tmux-pr-status "/path/to/repo"
# Output: Formatted tmux status string or empty if no PR

set -e

PANE_PATH="${1:-$(pwd)}"
CACHE_DIR="$HOME/.cache/tmux-pr-status"
CACHE_TTL=60  # seconds

# Fail silently for any error
trap 'exit 0' ERR

# Check if directory exists and is a git repo
cd "$PANE_PATH" 2>/dev/null || exit 0
git rev-parse --git-dir >/dev/null 2>&1 || exit 0

# Get current branch
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0

# Skip main/master branches
[[ "$BRANCH" == "main" || "$BRANCH" == "master" ]] && exit 0

# Generate cache key from repo root path
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
REPO_HASH=$(echo -n "$REPO_ROOT" | md5)
BRANCH_SAFE=$(echo "$BRANCH" | tr '/' '__')
CACHE_FILE="$CACHE_DIR/${REPO_HASH}_${BRANCH_SAFE}.cache"

# Ensure cache directory exists
mkdir -p "$CACHE_DIR"

# Check cache freshness
if [[ -f "$CACHE_FILE" ]]; then
    CACHE_AGE=$(($(date +%s) - $(stat -f %m "$CACHE_FILE")))
    if [[ $CACHE_AGE -lt $CACHE_TTL ]]; then
        cat "$CACHE_FILE"
        exit 0
    fi
fi

# Fetch PR data from GitHub
PR_JSON=$(gh pr view --json state,reviewDecision,statusCheckRollup,isDraft 2>/dev/null) || {
    # No PR for this branch - cache empty result
    echo -n "" > "$CACHE_FILE"
    exit 0
}

# Parse PR data
STATE=$(echo "$PR_JSON" | jq -r '.state // empty')
IS_DRAFT=$(echo "$PR_JSON" | jq -r '.isDraft // false')
REVIEW=$(echo "$PR_JSON" | jq -r '.reviewDecision // empty')
CI_STATUS=$(echo "$PR_JSON" | jq -r '
    .statusCheckRollup
    | if . == null or length == 0 then "NONE"
    elif any(.conclusion == "FAILURE" or .conclusion == "CANCELLED") then "FAILURE"
    elif any(.status == "IN_PROGRESS" or .status == "QUEUED" or .status == "PENDING") then "PENDING"
    elif all(.conclusion == "SUCCESS" or .conclusion == "SKIPPED" or .conclusion == "NEUTRAL") then "SUCCESS"
    else "UNKNOWN"
    end
')

# Skip closed/merged PRs
[[ "$STATE" != "OPEN" ]] && {
    echo -n "" > "$CACHE_FILE"
    exit 0
}

# Colors from environment (see zshrc TMUX_COLOR_*)
green="${TMUX_COLOR_GREEN:-#39d353}"
purple="${TMUX_COLOR_PURPLE:-#bd93f9}"
orange="${TMUX_COLOR_YELLOW:-#ffb86c}"
red="${TMUX_COLOR_RED:-#ff5555}"
yellow="#f1fa8c"  # CI pending (lighter yellow, not in palette)
grey="${TMUX_COLOR_GREY:-#6272a4}"

# Build output
output=""

# Draft PR indicator
if [[ "$IS_DRAFT" == "true" ]]; then
    output="#[fg=$grey]◇ "
else
    # Review status indicator
    case "$REVIEW" in
        "APPROVED")
            output="#[fg=$green]✓"
            ;;
        "CHANGES_REQUESTED")
            output="#[fg=$orange]!"
            ;;
        "REVIEW_REQUIRED"|"")
            output="#[fg=$purple]◎"
            ;;
        *)
            output="#[fg=$grey]○"
            ;;
    esac

    # CI status indicator
    case "$CI_STATUS" in
        "SUCCESS")
            output="${output}#[fg=$green]✓"
            ;;
        "FAILURE")
            output="${output}#[fg=$red]✗"
            ;;
        "PENDING")
            output="${output}#[fg=$yellow]○"
            ;;
        *)
            # No CI or unknown - skip CI indicator
            ;;
    esac

    output="${output} "
fi

# Cache and output result
echo -n "$output" > "$CACHE_FILE"
cat "$CACHE_FILE"
