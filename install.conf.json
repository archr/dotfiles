[
  {
    "clean": ["~", "~/.config"]
  },
  {
    "create": ["~/.config/ghostty"]
  },
  {
    "link": {
      "~/.tmux.conf": {
        "force": true,
        "path": "tmux.conf"
      },
      "~/.config/nvim/init.lua": {
        "force": true,
        "path": "nvim/init.lua"
      },
      "~/.config/ghostty/config": {
        "force": true,
        "path": "ghostty/config"
      }
    }
  }
]
