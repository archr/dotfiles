[
  {
    "clean": ["~", "~/.config"]
  },
  {
    "create": ["~/.config/ghostty", "~/Library/Application Support/lazygit", "~/.local/bin"]
  },
  {
    "link": {
      "~/.tmux.conf": {
        "force": true,
        "path": "tmux.conf"
      },
      "~/.config/nvim/init.lua": {
        "force": true,
        "path": "nvim/init.lua"
      },
      "~/.config/ghostty/config": {
        "force": true,
        "path": "ghostty/config"
      },
      "~/.local/bin/merge-to-dev.sh": {
        "force": true,
        "path": "bin/merge-to-dev.sh"
      },
      "~/.local/bin/pull-main.sh": {
        "force": true,
        "path": "bin/pull-main.sh"
      },
      "~/.local/bin/push-no-verify.sh": {
        "force": true,
        "path": "bin/push-no-verify.sh"
      },
      "~/.local/bin/tmux-claude-status": {
        "force": true,
        "path": "bin/tmux-claude-status"
      },
      "~/.local/bin/tmux-pr-status": {
        "force": true,
        "path": "bin/tmux-pr-status"
      },
      "~/.zshrc": {
        "force": true,
        "path": "zshrc"
      },
      "~/Library/Application Support/lazygit/config.yml": {
        "force": true,
        "path": "lazygit/config.yml"
      }
    }
  }
]
